{
  "name": "dbpilot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:api": "npm run dev --workspace=@dbpilot/api",
    "dev:web": "npm run dev --workspace=@dbpilot/web"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {}
}
